	Rent/(P K+eps)
	~	
	~	Средние доходы капиталистов
	|

thta inv=
	0.44
	~	
	~	base 0.35
	|

xi b=
	1.8
	~	
	~		|

yy R=
	1
	~	
	~		|

E A=
	eps A*A
	~	
	~		|

E H=
	eps H*H
	~	
	~		|

E net=
	E g*(1-1/eta)
	~	
	~	Net energy
	|

E Q=
	eps Q*Q
	~	
	~		|

E tech=
	E A + E H + E Q
	~	
	~		|

K E=
	1 + kappa A*A + kappa H*H
	~	
	~	эффективный “энерго-капитал”
	|

K p=
	1 + kappa pA*A + kappa pH*H
	~	
	~	эфффективный агро-капитал
	|

L arb= INTEG (
	-L arb*0.002,
		1)
	~	
	~	Пахотная земля
	|

Ph= INTEG (
	-P ext,
		2)
	~	
	~	Фосфор (отраэает все удобрения)
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year [0,?]
	~	The time step for the simulation.
	|

