	~	Эффективная занятость - реальный сектор
	|

wagePool=
	(1-alpha)*Y
	~	CU/Year
	~	Фонд оплаты труда
	|

phi=
	0.7
	~	Dmnl
	~		|

psi=
	0.6
	~	Dmnl
	~		|

Q 12=
	0.8
	~	CU
	~	0.6
	|

Yld=
	Yld 0*f E ag*f fert*F s
	~	Food/(Land*Year)
	~	Урожайность
	|

yy A=
	0.45
	~	CU/Year
	~	0.35 0.45
	|

r G=
	0.05
	~	1/Year
	~	0.06
	|

r soil=
	0.01
	~	1/Year
	~		|

r T=
	0.025
	~	1/Year
	~	0.05
	|

ro fert=
	0.2
	~	Fert/Energy
	~		|

Tax W=
	tax W rate*wagePool
	~	CU/Year
	~		|

s 0 W=
	0.6
	~	Dmnl
	~	25% “direct labor + provisioning ops” от населения в базовой \
		эпохе
		0.25
	|

s E ag=
	0.22
	~	Dmnl
	~	base 0.3
	|

s E house=
	0.33
	~	Dmnl
	~	base 0.25
	|

theta sec=
	0.5
	~	1/Year
	~	base 0.15
	|

s E sec=
	0.12
	~	Dmnl
	~	base 0.1
	|

theta U=
	0.2
	~	1/Year
	~	base 0.25
	|

s task A=
	EXP(-k Q * Q)
	~	Dmnl
	~	Доли “человеческих задач” для \
		абсорбционного сектора
	|

U=
	P U/P
	~	Dmnl
	~		|

SEC=
	theta sec*B g plus
	~	CU/Year
	~	Расходы на безоспасность
	|

waste=
	0.2
	~	Dmnl
	~	Отходы продуктов питания
	|

SVC=
	theta SVC*B g plus
	~	CU/Year
	~	Услуги в натуре
	|

T 12=
	0.35
	~	Dmnl
	~		|

T eff=
	MAX(0, MIN(1, T ) )
	~	Dmnl
	~		|

T max=
	1
	~	Dmnl
	~		|

T U=
	theta U*B g plus
	~	CU/Year
	~	Пособие по безработице
	|

tau A=
	28
	~	Year
	~	Амортизация A
		18/24/28
	|

tau H=
	16
	~	Year
	~	Амортизация H
		10/14/16
	|

tax K rate=
	0.2
	~	Dmnl
	~	base 0.25
	|

tau Q=
	12
	~	Year
	~	Амортизация Q
		6/10/12
	|

tau sol=
	40
	~	Year
	~		|

tax W rate=
	0.45
	~	Dmnl
	~	base 0.15
	|

Tax K=
	tax K rate*Rent
	~	CU/Year
	~		|

Y=
	Y R + Y A
	~	CU/Year
	~		|

Yld 0=
	50
	~	Food/(Land*Year*Fert)
	~	*0.7
	|

theta SVC=
	0.2
	~	1/Year
	~	base 0.25
	|

thta inv=
	0.1
	~	1/Year
	~	base 0.35 0.44
	|

xi b=
	1.8
	~	Dmnl
	~		|

yy R=
	1
	~	CU/Year
	~		|

E H=
	eps H*H
	~	Energy/Year
	~		|

E net=
	E g*(1-1/eta)
	~	Energy/Year
	~	Net energy
	|

E Q=
	eps Q*Q
	~	Energy/Year
	~		|

E tech=
	E A + E H + E Q
	~	Energy/Year
	~		|

Ph= INTEG (
	-P ext,
		2)
	~	Fert
	~	Фосфор (отраэает все удобрения)
	|

