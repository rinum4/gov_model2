{UTF-8}
C
	= INTEG (
	IF THEN ELSE(C<1, r C*(b1*Gap + b2*f c 12/(food pc norm+f c 12) + b3*Ineq eff)*(1 - \
		C) , 0) - IF THEN ELSE(C>0, d C*C*(
	1 + mu sec
	*SEC core) , 0 ),
		0.3)
	~	Dmnl
	~	Конфликт
		r C*(b1*Gap + b2*f c 12/(food pc+f c 12) + b3*Ineq eff) - d C*SEC/(SEC+SEC \
		12)
	|

uU elit=
	w y*yy elit norm + w s*SEC core - w c*C - w sec*SEC norm - w r*CollapseRisk
	~	Dmnl
	~		|

SEC 0=
	0.11
	~	CU/Year
	~		|

eps2=
	0.001
	~	Pop
	~		|

eps3=
	0.001
	~	Pop
	~		|

SEC norm=
	SEC/SEC 0
	~	Dmnl
	~		|

tau arb=
	0.002
	~	1/Year
	~		|

L arb= INTEG (
	-L arb*tau arb,
		1)
	~	Land
	~	Пахотная земля
	|

P eff=
	MAX(eps2, P )
	~	Pop
	~		|

U elit= INTEG (
	w y*yy elit norm + w s*SEC core - w c*C - w sec*SEC norm - w r*CollapseRisk,
		0)
	~	Year
	~		|

yy W=
	wagePool net/(P W + P A + eps3)
	~	CU/(Pop*Year)
	~	Средние доходы работников
	|

yy elit=
	Rent net/(P K + eps3)
	~	CU/(Pop*Year)
	~		|

yy K=
	Rent net/(P K+eps3)
	~	CU/(Pop*Year)
	~	Средние доходы капиталистов
	|

T= INTEG (
	IF THEN ELSE( T<1 , r T*(T max - T) , 0 ) - IF THEN ELSE( T>0 , d T* (a1*Gap + a2*Ineq eff\
		 + a3*C eff + a4*(f c 12/(food pc norm
	+f c 12)) + a5*(1 - G eff) + a6*CollapseRisk) , 0 ),
		0.6)
	~	Dmnl
	~	Доверие/обратная прозрачность
		r T*(T max - T) - d T* (a1*Gap + a2*Ineq eff + a3*C eff + a4*(f c 12/(food \
		pc+f c 12)) + a5*(1 - G eff) + a6*CollapseRisk))
	|

CollapseRisk=
	0.4*0.5/(food pc norm + 0.5) + 0.4*0.4/(G + 0.4) + 0.2*C/(C + 0.35)
	~	Dmnl
	~	Вероятность коллапса
	|

Rent Pop=
	MAX(0, alpha*Y*(1-k A priv) - Cost maint pop)
	~	CU/Year
	~		|

A pop= INTEG (
	I tot - A pop/tau A,
		0.12)
	~	CU
	~		|

B g= INTEG (
	Tax K + Tax W + Rent Pop - IF THEN ELSE(B g > 0, (T U + SVC + SEC + I tot ) , 0 ),
		0.215)
	~	CU
	~	Госбюджет 0.1
	|

A= INTEG (
	I priv A - A/tau A,
		0.6)
	~	CU
	~	Индустриальная автоматизация
	|

s task R=
	EXP(-k A*A tot - k H*H)
	~	Dmnl
	~	Доли “человеческих задач” для \
		реального сектора
	|

A tot=
	A + A pop
	~	CU
	~		|

