	c A * A pop
	~	CU/Year
	~		|

H= INTEG (
	I priv H - H/tau H,
		0.03)
	~	CU
	~	Парк гуманоидов (роботы)
	|

Q= INTEG (
	I priv Q - Q/tau Q,
		0.03)
	~	CU
	~	Когнитивная автоматизация (AI-capability deployed)
	|

k A priv=
	A / A tot
	~	Dmnl
	~		|

alpha=
	aplha 0 + aplha A * (A tot/(A tot + A 12)) + aplha H * (H/(H + H 12)) + aplha Q * (Q\
		/(Q + Q 12))
	~	Dmnl
	~	Доля капитала в выпуске
	|

Rent=
	MAX(0, alpha*Y*k A priv - Cost maint - Cost sec )
